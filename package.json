{
  "name": "@evo-agents/evo-cortex",
  "version": "1.0.0",
  "description": "完整的记忆、学习和进化能力 - OpenClaw 插件",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "evo-cortex",
    "memory",
    "knowledge",
    "evolution",
    "ai",
    "agent"
  ],
  "author": "Evo-Agents Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luoboask/evo-cortex.git"
  },
  "bugs": {
    "url": "https://github.com/luoboask/evo-cortex/issues"
  },
  "homepage": "https://github.com/luoboask/evo-cortex#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "scripts": {
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "echo \"No linting specified\" && exit 0",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "perf:report": "tsx scripts/generate-perf-report.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
