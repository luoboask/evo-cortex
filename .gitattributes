# Shell 脚本使用 LF
*.sh text eol=lf

# TypeScript 使用 LF
*.ts text eol=lf

# JavaScript 使用 LF
*.js text eol=lf

# Markdown 使用 LF
*.md text eol=lf

# JSON 使用 LF
*.json text eol=lf

# YAML 使用 LF
*.yml text eol=lf
*.yaml text eol=lf

# Windows 批处理使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 强制 LF 对于配置文件
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
